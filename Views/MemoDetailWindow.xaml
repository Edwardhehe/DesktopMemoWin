<Window x:Class="DesktopMemo.Views.MemoDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="备忘录详情" 
        Height="300" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinHeight="250"
        MinWidth="400">
    
    <Window.Resources>
        <!-- 阴影效果 -->
        <DropShadowEffect x:Key="DropShadowEffect" 
                          Color="Black" 
                          Direction="270" 
                          ShadowDepth="3" 
                          BlurRadius="10" 
                          Opacity="0.3"/>
        
        <!-- 按钮样式 -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#66FFFFFF"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#99E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 主要按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5A9FE2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#AAFFFFFF" CornerRadius="18" BorderBrush="#00FFFFFF" BorderThickness="0" Effect="{StaticResource DropShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" Height="34" Background="#66FFFFFF" BorderBrush="#00FFFFFF" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📝 备忘录详情" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="15,0" Foreground="#2D3748"/>
                    <Button Grid.Column="1" Content="✕" Click="CloseButton_Click" Style="{StaticResource ModernButtonStyle}" Width="30" Height="25" Margin="0,0,15,0" ToolTip="关闭"/>
                </Grid>
            </Border>
            
            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="15">
                <StackPanel>
                    <!-- 内容显示 -->
                    <Border Background="White"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,15">
                        <TextBlock x:Name="ContentTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="20"
                                   Foreground="#2D3748"/>
                    </Border>
                    
                    <!-- 日期信息 -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <TextBlock Text="创建日期：" 
                                   FontSize="12" 
                                   Foreground="#718096"/>
                        <TextBlock x:Name="CreatedDateTextBlock"
                                   FontSize="12" 
                                   Foreground="#2D3748"
                                   Margin="5,0,0,0"/>
                        <TextBlock Text=" | 备忘录日期：" 
                                   FontSize="12" 
                                   Foreground="#718096"
                                   Margin="15,0,0,0"/>
                        <TextBlock x:Name="MemoDateTextBlock"
                                   FontSize="12" 
                                   Foreground="#2D3748"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                    
                    <!-- 状态信息 -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <TextBlock Text="状态：" 
                                   FontSize="12" 
                                   Foreground="#718096"/>
                        <TextBlock x:Name="StatusTextBlock"
                                   FontSize="12" 
                                   Foreground="#2D3748"
                                   Margin="5,0,0,0"/>
                        <TextBlock x:Name="CompletedDateTextBlock"
                                   FontSize="12" 
                                   Foreground="#718096"
                                   Margin="15,0,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            
            <!-- 按钮区域 -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14" Height="34" Background="#66FFFFFF" BorderBrush="#00FFFFFF" BorderThickness="0">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <Button Content="编辑" 
                            x:Name="EditButton"
                            Click="EditButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="80" 
                            Height="25" 
                            Margin="0,0,10,0"/>
                    <Button Content="关闭" 
                            Click="CloseButton_Click" 
                            Style="{StaticResource ModernButtonStyle}"
                            Width="80" 
                            Height="25"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window> 