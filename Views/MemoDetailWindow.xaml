<Window x:Class="DesktopMemo.Views.MemoDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="备忘录详情"
        Height="360"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinHeight="300"
        MinWidth="440">

    <Window.Resources>
        <LinearGradientBrush x:Key="DialogSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4EEF2" Offset="0"/>
            <GradientStop Color="#EEE7EC" Offset="0.62"/>
            <GradientStop Color="#E6DAD9" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBrush" Color="#9F8FBEF5"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#B5A5CDF8"/>
        <DropShadowEffect x:Key="DropShadowEffect"
                          Color="#35557C"
                          Direction="270"
                          ShadowDepth="12"
                          BlurRadius="26"
                          Opacity="0.14"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#BFF8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="#23415F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D8F5F8FC"/>
                                <Setter Property="BorderBrush" Value="#DDE4EE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource DialogSurfaceBrush}" CornerRadius="28" BorderBrush="#D8CFD6" BorderThickness="1.2" Opacity="0.98" Effect="{StaticResource DropShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="27,27,0,0" Height="56" Background="#DDF3EEF5" BorderBrush="#CFC6CF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📝 备忘录详情" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="18,0" Foreground="#214162"/>
                    <Button Grid.Column="1" Content="✕" Click="CloseButton_Click" Style="{StaticResource ModernButtonStyle}" Width="34" Height="32" Margin="0,0,15,0" ToolTip="关闭"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="18,16,18,14">
                <StackPanel>
                    <Border Background="#FFFFFF"
                            BorderBrush="#D7CDD4"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="18"
                            Margin="0,0,0,14">
                        <TextBlock x:Name="ContentTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="24"
                                   Foreground="#24415F"/>
                    </Border>

                    <Border Background="#D7F3EEF2"
                            BorderBrush="#D7CDD4"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="信息概览"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#23415F"
                                       Margin="0,0,0,12"/>
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Text="创建日期："
                                           FontSize="12"
                                           Foreground="#73869C"/>
                                <TextBlock x:Name="CreatedDateTextBlock"
                                           FontSize="12"
                                           Foreground="#24415F"
                                           Margin="4,0,18,0"/>
                                <TextBlock Text="备忘录日期："
                                           FontSize="12"
                                           Foreground="#73869C"/>
                                <TextBlock x:Name="MemoDateTextBlock"
                                           FontSize="12"
                                           Foreground="#24415F"
                                           Margin="4,0,0,0"/>
                            </WrapPanel>
                            <WrapPanel>
                                <TextBlock Text="状态："
                                           FontSize="12"
                                           Foreground="#73869C"/>
                                <TextBlock x:Name="StatusTextBlock"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#24415F"
                                           Margin="4,0,18,0"/>
                                <TextBlock Text="优先级："
                                           FontSize="12"
                                           Foreground="#73869C"/>
                                <TextBlock x:Name="PriorityTextBlock"
                                           FontSize="12"
                                           Foreground="#24415F"
                                           Margin="4,0,18,0"/>
                                <TextBlock Text="置顶："
                                           FontSize="12"
                                           Foreground="#73869C"/>
                                <TextBlock x:Name="PinnedTextBlock"
                                           FontSize="12"
                                           Foreground="#24415F"
                                           Margin="4,0,18,0"/>
                                <TextBlock x:Name="CompletedDateTextBlock"
                                           FontSize="12"
                                           Foreground="#73869C"
                                           Visibility="Collapsed"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" CornerRadius="0,0,27,27" Height="48" Background="#D9F2ECEF" BorderBrush="#D5CCD4" BorderThickness="1,1,1,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,18,0">
                    <Button Content="编辑"
                            x:Name="EditButton"
                            Click="EditButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="84"
                            Height="32"
                            Margin="0,0,10,0"/>
                    <Button Content="关闭"
                            Click="CloseButton_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="84"
                            Height="32"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
