<Window x:Class="DesktopMemo.Views.MemoDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="备忘录详情" 
        Height="300" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White"
        MinHeight="250"
        MinWidth="400">
    
    <Border Background="White" 
            CornerRadius="8" 
            BorderBrush="#E0E0E0" 
            BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题 -->
            <TextBlock Grid.Row="0" 
                       Text="备忘录详情" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="#333333"
                       Margin="0,0,0,15"/>
            
            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Border Background="#F8F8F8"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="15">
                    <TextBlock x:Name="ContentTextBlock"
                               TextWrapping="Wrap"
                               FontSize="14"
                               LineHeight="20"
                               Foreground="#333333"/>
                </Border>
            </ScrollViewer>
            
            <!-- 日期信息 -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal"
                        Margin="0,15,0,0">
                <TextBlock Text="创建日期：" 
                           FontSize="12" 
                           Foreground="#666666"/>
                <TextBlock x:Name="CreatedDateTextBlock"
                           FontSize="12" 
                           Foreground="#333333"
                           Margin="5,0,0,0"/>
                <TextBlock Text=" | 备忘录日期：" 
                           FontSize="12" 
                           Foreground="#666666"
                           Margin="15,0,0,0"/>
                <TextBlock x:Name="MemoDateTextBlock"
                           FontSize="12" 
                           Foreground="#333333"
                           Margin="5,0,0,0"/>
            </StackPanel>
            
            <!-- 状态信息 -->
            <StackPanel Grid.Row="3" 
                        Orientation="Horizontal"
                        Margin="0,10,0,0">
                <TextBlock Text="状态：" 
                           FontSize="12" 
                           Foreground="#666666"/>
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="12" 
                           Foreground="#333333"
                           Margin="5,0,0,0"/>
                <TextBlock x:Name="CompletedDateTextBlock"
                           FontSize="12" 
                           Foreground="#666666"
                           Margin="15,0,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
            
            <!-- 按钮区域 -->
            <StackPanel Grid.Row="4" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button Content="编辑" 
                        x:Name="EditButton"
                        Click="EditButton_Click"
                        Width="80" 
                        Height="32" 
                        Margin="0,0,10,0"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#005A9E"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#004578"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="关闭" 
                        Click="CloseButton_Click" 
                        Width="80" 
                        Height="32"
                        Background="#F0F0F0"
                        Foreground="#333333"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        FontSize="12"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#F0F0F0"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#D0D0D0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window> 