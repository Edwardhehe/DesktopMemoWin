<Window x:Class="DesktopMemo.Views.MemoInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="备忘录"
        FontFamily="Microsoft YaHei UI"
        Height="420"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <LinearGradientBrush x:Key="DialogSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4EEF2" Offset="0"/>
            <GradientStop Color="#EEE7EC" Offset="0.62"/>
            <GradientStop Color="#E6DAD9" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBrush" Color="#9F8FBEF5"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#B5A5CDF8"/>
        <DropShadowEffect x:Key="DropShadowEffect"
                          Color="#35557C"
                          Direction="270"
                          ShadowDepth="12"
                          BlurRadius="26"
                          Opacity="0.14"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#BFF8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="#23415F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D8F5F8FC"/>
                                <Setter Property="BorderBrush" Value="#DDE4EE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource DialogSurfaceBrush}" CornerRadius="28" BorderBrush="#D8CFD6" BorderThickness="1.2" Opacity="0.98" Effect="{StaticResource DropShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="27,27,0,0" Height="56" Background="#DDF3EEF5" BorderBrush="#CFC6CF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleTextBlock"
                               Grid.Column="0"
                               Text="添加备忘录"
                               FontWeight="Bold"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="18,0"
                               Foreground="#214162"/>
                    <Button Grid.Column="1"
                            Content="×"
                            Click="CancelButton_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="34"
                            Height="32"
                            Margin="0,0,15,0"
                            ToolTip="关闭"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18,16,18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#D7F3EEF2" BorderBrush="#D7CDD4" BorderThickness="1" CornerRadius="18" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="内容"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#425B75"
                                   Margin="0,0,0,8"/>
                        <RichTextBox x:Name="ContentRichTextBox"
                                     Grid.Row="1"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="White"
                                     BorderBrush="#D5CAD4"
                                     BorderThickness="1"
                                     Padding="10"
                                     FontSize="12"
                                     Foreground="#2D3748"
                                     AcceptsReturn="True"
                                     DataObject.Pasting="ContentRichTextBox_Paste"
                                     KeyDown="ContentRichTextBox_KeyDown">
                            <FlowDocument>
                                <Paragraph x:Name="ContentParagraph"/>
                            </FlowDocument>
                        </RichTextBox>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#D7F3EEF2" BorderBrush="#D7CDD4" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="日期"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#425B75"/>
                        <DatePicker x:Name="DatePicker"
                                    Grid.Column="1"
                                    FontSize="11"
                                    BorderBrush="#D5CAD4"
                                    BorderThickness="1"
                                    Padding="4,2"
                                    Margin="10,0,16,0"
                                    VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="优先级"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#425B75"/>
                        <ComboBox x:Name="PriorityComboBox"
                                  Grid.Column="3"
                                  FontSize="11"
                                  Margin="10,0,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="低"/>
                            <ComboBoxItem Content="中"/>
                            <ComboBoxItem Content="高"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#D7F3EEF2" BorderBrush="#D7CDD4" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,12,0,0">
                    <CheckBox x:Name="PinnedCheckBox"
                              Content="置顶显示"
                              FontSize="11"
                              FontWeight="SemiBold"
                              Foreground="#425B75"/>
                </Border>
            </Grid>

            <Border Grid.Row="2" CornerRadius="0,0,27,27" Height="48" Background="#D9F2ECEF" BorderBrush="#D5CCD4" BorderThickness="1,1,1,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,18,0">
                    <Button Content="确定"
                            Click="OkButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="84"
                            Height="32"
                            Margin="0,0,10,0"/>
                    <Button Content="取消"
                            Click="CancelButton_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="84"
                            Height="32"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
