<Window x:Class="DesktopMemo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DesktopMemo.Converters"
        x:Name="MemoWindow"
        Title="桌面备忘录" 
        Height="800" 
        Width="750"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Top="0">
    
    <Window.Resources>
        <!-- 转换器 -->
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <local:BoolToForegroundConverter x:Key="BoolToForegroundConverter"/>
        <local:BoolToMemoStyleConverter x:Key="BoolToMemoStyleConverter"/>
        <local:BoolToTextDecorationConverter x:Key="BoolToTextDecorationConverter"/>
        <local:TextTruncateConverter x:Key="TextTruncateConverter"/>
        <local:TodayCalendarDayStyleConverter x:Key="TodayCalendarDayStyleConverter"/>
        <local:TodayForegroundConverter x:Key="TodayForegroundConverter"/>
        <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        
        
        <!-- 日历格子样式 -->
        <Style x:Key="CalendarDayStyle" TargetType="Border">
            <Setter Property="Background" Value="#66FFFFFF"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="MinHeight" Value="95"/>
            <Setter Property="Padding" Value="3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#99E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 当天日期格子样式 -->
        <Style x:Key="TodayCalendarDayStyle" TargetType="Border">
            <Setter Property="Background" Value="#B3E3F2FD"/>
            <Setter Property="BorderBrush" Value="#4A90E2"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="MinHeight" Value="95"/>
            <Setter Property="Padding" Value="3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCE3F2FD"/>
                    <Setter Property="BorderBrush" Value="#5A9FE2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 备忘录项样式 -->
        <Style x:Key="MemoItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#B3F8F9FA"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCE3F2FD"/>
                    <Setter Property="BorderBrush" Value="#4A90E2"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#4A90E2" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.6"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="CompletedMemoStyle" TargetType="Border">
            <Setter Property="Background" Value="#B3E8F5E8"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCE8F5E8"/>
                    <Setter Property="BorderBrush" Value="#28A745"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Opacity" Value="0.9"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#28A745" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 按钮样式 -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#66FFFFFF"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#99E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#AAFFFFFF" CornerRadius="18" BorderBrush="#00FFFFFF" BorderThickness="0" Effect="{StaticResource DropShadowEffect}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" Height="34" Background="#66FFFFFF" BorderBrush="#00FFFFFF" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <TextBlock Text="📝 桌面备忘录" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="#2D3748"/>
                        <TextBlock Text="{Binding CurrentMonth, StringFormat='yyyy年MM月'}" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="#718096"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                        <Button Content="◀" Command="{Binding PreviousMonthCommand}" Style="{StaticResource ModernButtonStyle}" Width="30" Height="25" Margin="3" ToolTip="上个月"/>
                        <Button Content="▶" Command="{Binding NextMonthCommand}" Style="{StaticResource ModernButtonStyle}" Width="30" Height="25" Margin="3" ToolTip="下个月"/>
                        <Button Content="⚙" Click="SettingsButton_Click" Style="{StaticResource ModernButtonStyle}" Width="35" Height="25" Margin="3" ToolTip="设置"/>
                        <Button Content="✕" Click="CloseButton_Click" Style="{StaticResource ModernButtonStyle}" Width="30" Height="25" Margin="3" ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 日历内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 星期标题 -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="日" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="一" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="二" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="三" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="四" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="五" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="六" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Grid>
                    
                    <!-- 日历网格 -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{Binding IsToday, Converter={StaticResource TodayCalendarDayStyleConverter}}"
                                        Opacity="{Binding IsCurrentMonth, Converter={StaticResource BoolToOpacityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 日期行 -->
                                        <Grid Grid.Row="0" Margin="2,2,2,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- 添加备忘录按钮 -->
                                            <Button Grid.Column="0"
                                                    Content="+" 
                                                    Command="{Binding DataContext.AddMemoCommand, Source={x:Reference MemoWindow}}" 
                                                    CommandParameter="{Binding}"
                                                    Width="18" 
                                                    Height="18" 
                                                    FontSize="11" 
                                                    FontWeight="Bold"
                                                    Margin="0,0,1,0"
                                                    Background="LightBlue"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    ToolTip="添加新备忘录"
                                                    Visibility="{Binding IsCurrentMonth, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        
                                                                                <!-- 日期数字 -->
                                            <TextBlock Grid.Column="2" 
                                                   Text="{Binding Date.Day}" 
                                                   HorizontalAlignment="Right" 
                                                       FontSize="11"
                                                   Margin="0,0,2,0"
                                                   FontWeight="{Binding IsToday, Converter={StaticResource BoolToFontWeightConverter}}"
                                                   Foreground="{Binding IsToday, Converter={StaticResource TodayForegroundConverter}}"
                                                   MouseLeftButtonDown="DateRow_MouseLeftButtonDown"
                                                   Tag="{Binding}"
                                                   Cursor="Hand"/>
                                        </Grid>
                                        
                                        <!-- 备忘录列表 -->
                                        <ScrollViewer Grid.Row="1" 
                                                      VerticalScrollBarVisibility="Hidden" 
                                                          HorizontalScrollBarVisibility="Disabled"
                                                      MaxHeight="68"
                                                      Margin="0,1,0,2">
                                                <ItemsControl ItemsSource="{Binding Memos}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{Binding IsCompleted, Converter={StaticResource BoolToMemoStyleConverter}}"
                                                                    MouseLeftButtonDown="MemoItem_MouseLeftButtonDown"
                                                                    Tag="{Binding}">
                                                            <Border.InputBindings>
                                                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.ShowMemoDetailCommand, Source={x:Reference MemoWindow}}" CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>
                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="删除备忘录"
                                                                                  Command="{Binding DataContext.DeleteMemoCommand, Source={x:Reference MemoWindow}}"
                                                                                  CommandParameter="{Binding}"/>
                                                                        <MenuItem Header="标记为已完成"
                                                                                  Command="{Binding DataContext.MarkCompletedCommand, Source={x:Reference MemoWindow}}"
                                                                                  CommandParameter="{Binding}"
                                                                                  Visibility="{Binding IsCompleted, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                                                        <MenuItem Header="标记为未完成"
                                                                                  Command="{Binding DataContext.MarkUncompletedCommand, Source={x:Reference MemoWindow}}"
                                                                                  CommandParameter="{Binding}"
                                                                                  Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <TextBlock Grid.Column="0" 
                                                                               Text="{Binding Content, Converter={StaticResource TextTruncateConverter}, ConverterParameter=8}" 
                                                                               TextWrapping="NoWrap" 
                                                                               TextTrimming="CharacterEllipsis"
                                                                               FontSize="9"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,1,0"
                                                                               ToolTip="{Binding Content}"
                                                                               TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToTextDecorationConverter}}"
                                                                               Foreground="#2D3748">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                                                        <Setter Property="Foreground" Value="#1A365D"/>
                                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    
                                                                    <Button Grid.Column="1"
                                                                            Content="✓" 
                                                                            Command="{Binding DataContext.MarkCompletedCommand, Source={x:Reference MemoWindow}}" 
                                                                            CommandParameter="{Binding}"
                                                                            Width="10" 
                                                                            Height="10" 
                                                                            FontSize="7" 
                                                                            Margin="1,0,0,0"
                                                                            Background="LightBlue"
                                                                            Foreground="White"
                                                                            BorderThickness="0"
                                                                            ToolTip="标记为完成"
                                                                            Visibility="{Binding IsCompleted, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{TemplateBinding Background}" CornerRadius="1">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="#28A745"/>
                                                                                        <Setter Property="Effect">
                                                                                            <Setter.Value>
                                                                                                <DropShadowEffect Color="#28A745" Direction="270" ShadowDepth="1" BlurRadius="2" Opacity="0.6"/>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
            
            <!-- 状态栏 -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14" Height="34" Background="#66FFFFFF" BorderBrush="#00FFFFFF" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <Ellipse Width="8" Height="8" Fill="#28A745" Margin="0,0,8,0"/>
                        <TextBlock Text="桌面备忘录正在运行中" VerticalAlignment="Center" FontSize="11" Foreground="#495057"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                        <CheckBox Content="开机启动" IsChecked="{Binding IsStartupEnabled}" VerticalAlignment="Center" FontSize="11" Foreground="#495057"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window> 