<Window x:Class="DesktopMemo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DesktopMemo.Converters"
        x:Name="MemoWindow"
        Title="桌面备忘录" 
        Height="750" 
        Width="850"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Top="0">
    
    <Window.Resources>
        
        
        <!-- 日历格子样式 -->
        <Style x:Key="CalendarDayStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="120"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 备忘录项样式 -->
        <Style x:Key="MemoItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
        
        <Style x:Key="CompletedMemoStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8F5E8"/>
            <Setter Property="BorderBrush" Value="#90EE90"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
        
        <!-- 按钮样式 -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5F3FF"/>
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="{Binding BackgroundColor}" 
            CornerRadius="12" 
            BorderBrush="#E0E0E0" 
            BorderThickness="1"
            Effect="{StaticResource DropShadowEffect}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Height="30">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F8F9FA" Offset="0"/>
                        <GradientStop Color="#E9ECEF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <TextBlock Text="📝 桌面备忘录" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="#2D3748"/>
                        <TextBlock Text="{Binding CurrentMonth, StringFormat='yyyy年MM月'}" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="#718096"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                        <Button Content="◀" Command="{Binding PreviousMonthCommand}" Style="{StaticResource ModernButtonStyle}" Width="30" Height="25" Margin="3" ToolTip="上个月"/>
                        <Button Content="▶" Command="{Binding NextMonthCommand}" Style="{StaticResource ModernButtonStyle}" Width="30" Height="25" Margin="3" ToolTip="下个月"/>
                        <Button Content="⚙" Click="SettingsButton_Click" Style="{StaticResource ModernButtonStyle}" Width="35" Height="25" Margin="3" ToolTip="设置"/>
                        <Button Content="✕" Click="CloseButton_Click" Style="{StaticResource ModernButtonStyle}" Width="30" Height="25" Margin="3" ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 日历内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 星期标题 -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="日" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="一" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="二" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="三" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="四" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="五" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="六" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Grid>
                    
                    <!-- 日历网格 -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CalendarDayStyle}"
                                        Opacity="{Binding IsCurrentMonth, Converter={StaticResource BoolToOpacityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 日期数字 -->
                                        <TextBlock Grid.Row="0" 
                                                   Text="{Binding Date.Day}" 
                                                   HorizontalAlignment="Right" 
                                                   Margin="5,2" 
                                                   FontSize="12"
                                                   Foreground="{Binding IsCurrentMonth, Converter={StaticResource BoolToForegroundConverter}}"/>
                                        
                                        <!-- 备忘录列表 -->
                                        <Grid Grid.Row="1" Margin="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- 备忘录条目 -->
                                            <ScrollViewer Grid.Row="0" 
                                                          VerticalScrollBarVisibility="Visible" 
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          MaxHeight="70">
                                                <ScrollViewer.Resources>
                                                    <Style TargetType="ScrollBar">
                                                        <Setter Property="Width" Value="6"/>
                                                        <Setter Property="Background" Value="#E0E0E0"/>
                                                        <Setter Property="BorderBrush" Value="#C0C0C0"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ScrollViewer.Resources>
                                                <ItemsControl ItemsSource="{Binding Memos}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{Binding IsCompleted, Converter={StaticResource BoolToMemoStyleConverter}}"
                                                                    MouseLeftButtonDown="MemoItem_MouseLeftButtonDown"
                                                                    Tag="{Binding}">
                                                                <Border.InputBindings>
                                                                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.ShowMemoDetailCommand, Source={x:Reference MemoWindow}}" CommandParameter="{Binding}"/>
                                                                </Border.InputBindings>
                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="删除备忘录" 
                                                                                  Command="{Binding DataContext.DeleteMemoCommand, Source={x:Reference MemoWindow}}"
                                                                                  CommandParameter="{Binding}"/>
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <TextBlock Grid.Column="0" 
                                                                               Text="{Binding Content, Converter={StaticResource TextTruncateConverter}, ConverterParameter=8}" 
                                                                               TextWrapping="NoWrap" 
                                                                               TextTrimming="CharacterEllipsis"
                                                                               FontSize="9"
                                                                               VerticalAlignment="Center"
                                                                               ToolTip="{Binding Content}"
                                                                               TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToTextDecorationConverter}}"/>
                                                                    
                                                                    <Button Grid.Column="1"
                                                                            Content="✓" 
                                                                            Command="{Binding DataContext.MarkCompletedCommand, Source={x:Reference MemoWindow}}" 
                                                                            CommandParameter="{Binding}"
                                                                            Width="11" 
                                                                            Height="11" 
                                                                            FontSize="8" 
                                                                            Margin="4,0,0,0"
                                                                            Background="LightBlue"
                                                                            Foreground="White"
                                                                            BorderThickness="0"
                                                                            ToolTip="标记为完成"
                                                                            Visibility="{Binding IsCompleted, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                            
                                            <!-- 添加备忘录按钮 -->
                                            <Button Grid.Row="1"
                                                    Content="+" 
                                                    Command="{Binding DataContext.AddMemoCommand, Source={x:Reference MemoWindow}}" 
                                                    CommandParameter="{Binding}"
                                                    Width="24" 
                                                    Height="20" 
                                                    FontSize="14" 
                                                    FontWeight="Bold"
                                                    Margin="0,2,0,0"
                                                    Background="LightBlue"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    ToolTip="添加新备忘录"
                                                    HorizontalAlignment="Left"
                                                    Visibility="{Binding IsCurrentMonth, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
            
            <!-- 状态栏 -->
            <Border Grid.Row="2" CornerRadius="0,0,12,12" Height="35">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#E9ECEF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <Ellipse Width="8" Height="8" Fill="#28A745" Margin="0,0,8,0"/>
                        <TextBlock Text="桌面备忘录正在运行中" VerticalAlignment="Center" FontSize="11" Foreground="#495057"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                        <CheckBox Content="开机启动" IsChecked="{Binding IsStartupEnabled}" VerticalAlignment="Center" FontSize="11" Foreground="#495057"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window> 