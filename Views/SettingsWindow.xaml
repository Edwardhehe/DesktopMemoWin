<Window x:Class="DesktopMemo.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        FontFamily="Microsoft YaHei UI"
        Height="480"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <LinearGradientBrush x:Key="DialogSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4EEF2" Offset="0"/>
            <GradientStop Color="#EEE7EC" Offset="0.62"/>
            <GradientStop Color="#E6DAD9" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBrush" Color="#9F8FBEF5"/>
        <DropShadowEffect x:Key="DropShadowEffect" Color="#35557C" Direction="270" ShadowDepth="12" BlurRadius="26" Opacity="0.14"/>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#BFF8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#23415F"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource DialogSurfaceBrush}" CornerRadius="28" BorderBrush="#D8CFD6" BorderThickness="1.2" Opacity="0.98" Effect="{StaticResource DropShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="27,27,0,0" Height="56" Background="#DDF3EEF5" BorderBrush="#CFC6CF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="设置" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="18,0" Foreground="#214162"/>
                    <Button Grid.Column="1" Content="×" Click="CancelButton_Click" Style="{StaticResource ModernButtonStyle}" Width="34" Height="32" Margin="0,0,15,0"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="18,16,18,14">
                <StackPanel>
                    <Border Background="#D7F3EEF2" BorderBrush="#D7CDD4" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="启动设置" FontWeight="Bold" FontSize="13" Foreground="#23415F" Margin="0,0,0,12"/>
                            <CheckBox Content="开机自动启动" IsChecked="{Binding StartupEnabled}" FontSize="11.5" FontWeight="SemiBold" Foreground="#425B75"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#D7F3EEF2" BorderBrush="#D7CDD4" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="外观设置" FontWeight="Bold" FontSize="13" Foreground="#23415F" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Width="60" Height="28" CornerRadius="14" BorderBrush="#D5CAD4" BorderThickness="1" Background="{Binding BackgroundPreviewBrush}" Margin="0,0,12,0"/>
                                <Button Content="切换背景色" Click="BackgroundColorButton_Click" Style="{StaticResource ModernButtonStyle}" Width="108" Height="30"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedBackgroundColor}" FontSize="10.5" Foreground="#73869C"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#D7F3EEF2" BorderBrush="#D7CDD4" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="数据管理" FontWeight="Bold" FontSize="13" Foreground="#23415F" Margin="0,0,0,12"/>
                            <WrapPanel Margin="0,0,0,8">
                                <Button Content="导出数据" Click="ExportDataButton_Click" Style="{StaticResource ModernButtonStyle}" Width="88" Height="30" Margin="0,0,10,10"/>
                                <Button Content="导入数据" Click="ImportDataButton_Click" Style="{StaticResource ModernButtonStyle}" Width="88" Height="30" Margin="0,0,10,10"/>
                                <Button Content="清空全部" Click="ClearDataButton_Click" Style="{StaticResource ModernButtonStyle}" Width="88" Height="30" Margin="0,0,10,10"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#D7F3EEF2" BorderBrush="#D7CDD4" BorderThickness="1" CornerRadius="18" Padding="18">
                        <StackPanel>
                            <TextBlock Text="回收站" FontWeight="Bold" FontSize="13" Foreground="#23415F" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding RecycleBinCount, StringFormat='当前共有 {0} 条已删除备忘录'}" FontSize="11" Foreground="#425B75" Margin="0,0,0,10"/>
                            <Button Content="清空回收站" Click="EmptyRecycleBinButton_Click" Style="{StaticResource ModernButtonStyle}" Width="108" Height="30"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" CornerRadius="0,0,27,27" Height="48" Background="#D9F2ECEF" BorderBrush="#D5CCD4" BorderThickness="1,1,1,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Button Content="确定" Click="OkButton_Click" Background="{StaticResource AccentBrush}" Foreground="White" Width="84" Height="32" FontSize="11" Margin="0,0,10,0"/>
                    <Button Content="取消" Click="CancelButton_Click" Style="{StaticResource ModernButtonStyle}" Width="84" Height="32"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
