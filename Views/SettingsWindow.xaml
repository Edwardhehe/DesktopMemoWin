<Window x:Class="DesktopMemo.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="440"
        Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <LinearGradientBrush x:Key="DialogSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4EEF2" Offset="0"/>
            <GradientStop Color="#EEE7EC" Offset="0.62"/>
            <GradientStop Color="#E6DAD9" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBrush" Color="#9F8FBEF5"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#B5A5CDF8"/>
        <DropShadowEffect x:Key="DropShadowEffect"
                          Color="#35557C"
                          Direction="270"
                          ShadowDepth="12"
                          BlurRadius="26"
                          Opacity="0.14"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#BFF8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="#23415F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D8F5F8FC"/>
                                <Setter Property="BorderBrush" Value="#DDE4EE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Background" Value="#D7F3EEF2"/>
            <Setter Property="BorderBrush" Value="#D7CDD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#CBEFF1F6" CornerRadius="10" Padding="10,6" Margin="0,0,0,12">
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Foreground="#23415F"/>
                                </Border>
                                <ContentPresenter Grid.Row="1" Content="{TemplateBinding Content}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource DialogSurfaceBrush}" CornerRadius="28" BorderBrush="#D8CFD6" BorderThickness="1.2" Opacity="0.98" Effect="{StaticResource DropShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="27,27,0,0" Height="56" Background="#DDF3EEF5" BorderBrush="#CFC6CF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⚙ 设置" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="18,0" Foreground="#214162"/>
                    <Button Grid.Column="1" Content="✕" Click="CancelButton_Click" Style="{StaticResource ModernButtonStyle}" Width="34" Height="32" Margin="0,0,15,0" ToolTip="关闭"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="18,16,18,14">
                <StackPanel>
                    <GroupBox Header="启动设置" Style="{StaticResource ModernGroupBoxStyle}">
                        <StackPanel>
                            <CheckBox Content="开机自动启动"
                                      IsChecked="{Binding StartupEnabled}"
                                      Margin="0,5"
                                      FontSize="12"
                                      FontWeight="SemiBold"
                                      Foreground="#425B75"/>
                            <TextBlock Text="启用后，系统启动时会自动运行桌面备忘录"
                                       FontSize="11"
                                       Foreground="#73869C"
                                       Margin="22,2,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="外观设置" Style="{StaticResource ModernGroupBoxStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8" VerticalAlignment="Center">
                                <Border Width="60"
                                        Height="28"
                                        CornerRadius="14"
                                        BorderBrush="#D5CAD4"
                                        BorderThickness="1"
                                        Background="{Binding BackgroundPreviewBrush}"
                                        Margin="0,0,12,0"/>
                                <Button Content="切换背景色"
                                        Click="BackgroundColorButton_Click"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Width="108"
                                        Height="30"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedBackgroundColor}"
                                       FontSize="11"
                                       Foreground="#73869C"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="确定后应用到主界面，取消则不保存当前选择。"
                                       FontSize="11"
                                       Foreground="#73869C"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="数据管理" Style="{StaticResource ModernGroupBoxStyle}">
                        <StackPanel>
                            <WrapPanel Margin="0,4,0,8">
                                <Button Content="导出数据"
                                        Click="ExportDataButton_Click"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Width="88"
                                        Height="30"
                                        Margin="0,0,10,10"/>
                                <Button Content="导入数据"
                                        Click="ImportDataButton_Click"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Width="88"
                                        Height="30"
                                        Margin="0,0,10,10"/>
                                <Button Content="清空数据"
                                        Click="ClearDataButton_Click"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Width="88"
                                        Height="30"
                                        Margin="0,0,10,10"/>
                            </WrapPanel>
                            <TextBlock Text="导出数据可以将备忘录备份到其他位置，导入数据可以从备份文件恢复备忘录。"
                                       FontSize="11"
                                       Foreground="#73869C"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="关于" Style="{StaticResource ModernGroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Text="桌面备忘录 v1.0.0"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Foreground="#214162"
                                       Margin="0,4,0,8"/>
                            <TextBlock Text="一个简单的桌面背景备忘录软件"
                                       FontSize="11"
                                       Foreground="#73869C"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="技术栈：.NET 8 WPF + SQLite"
                                       FontSize="11"
                                       Foreground="#73869C"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="支持 Windows 10 及以上系统"
                                       FontSize="11"
                                       Foreground="#73869C"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" CornerRadius="0,0,27,27" Height="48" Background="#D9F2ECEF" BorderBrush="#D5CCD4" BorderThickness="1,1,1,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,18,0">
                    <Button Content="确定"
                            Click="OkButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="84"
                            Height="32"
                            Margin="0,0,10,0"/>
                    <Button Content="取消"
                            Click="CancelButton_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="84"
                            Height="32"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
