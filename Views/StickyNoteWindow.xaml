<Window x:Class="DesktopMemo.Views.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="侧边便签"
        FontFamily="Microsoft YaHei UI"
        Width="320"
        Height="420"
        MinWidth="240"
        MinHeight="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False">

    <Window.Resources>
        <LinearGradientBrush x:Key="NoteSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4EEF2" Offset="0"/>
            <GradientStop Color="#EEE7EC" Offset="0.56"/>
            <GradientStop Color="#E6DAD9" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBrush" Color="#9F8FBEF5"/>
        <DropShadowEffect x:Key="DropShadowEffect" Color="#35557C" Direction="270" ShadowDepth="12" BlurRadius="28" Opacity="0.14"/>
    </Window.Resources>

    <Border Background="{StaticResource NoteSurfaceBrush}"
            CornerRadius="28"
            BorderBrush="#D8CFD6"
            BorderThickness="1.2"
            Opacity="0.98"
            Effect="{StaticResource DropShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#DDF3EEF5"
                    BorderBrush="#CFC6CF"
                    BorderThickness="0,0,0,1"
                    CornerRadius="27,27,0,0"
                    MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="侧边便签"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#214162"/>
                    <TextBlock Grid.Column="1"
                               Text="可拖动"
                               VerticalAlignment="Center"
                               FontSize="10.5"
                               Foreground="#70839A"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="12,10,12,8">
                <RichTextBox x:Name="EditorRichTextBox"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#24415F"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsTab="True"
                             AllowDrop="True"
                             TextChanged="EditorRichTextBox_TextChanged"
                             PreviewDragOver="EditorRichTextBox_PreviewDragOver"
                             Drop="EditorRichTextBox_Drop"
                             DataObject.Pasting="EditorRichTextBox_Pasting">
                    <FlowDocument PagePadding="0"
                                  FontFamily="Microsoft YaHei UI"
                                  FontSize="12"
                                  Foreground="#24415F"
                                  LineHeight="20">
                        <Paragraph Margin="0"/>
                    </FlowDocument>
                </RichTextBox>

                <Thumb x:Name="ResizeThumb"
                       Width="18"
                       Height="18"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Cursor="SizeNWSE"
                       Margin="0,0,-4,-4"
                       DragDelta="ResizeThumb_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Grid Width="18" Height="18">
                                <Path Stroke="#8EA9C6"
                                      StrokeThickness="1.2"
                                      Data="M 4 14 L 14 4 M 8 14 L 14 8 M 12 14 L 14 12"/>
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>

            <Border Grid.Row="2"
                    Background="#D9F2ECEF"
                    BorderBrush="#D5CCD4"
                    BorderThickness="1,1,1,0"
                    CornerRadius="0,0,27,27">
                <TextBlock Text="支持滚动、粘贴文字和图片"
                           Margin="14,0"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="#73869C"/>
            </Border>
        </Grid>
    </Border>
</Window>
